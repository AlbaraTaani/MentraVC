      },
      "configuration" : {
        "scriptLang" : "JS",
        "jsScript" : "var isParking = metadata.ss_is_bus_parking === 'true';\r\nvar stopsCount = parseInt(metadata.ss_current_stops_count || '0');\r\nvar maxStops = parseInt(metadata.ss_number_of_stops || '2');\r\n\r\nif (isParking) {\r\n    // Bus is already fully parked. Keep overwriting the parked location with the newest point.\r\n    return ['UpdateParkedData']; \r\n} else {\r\n    stopsCount++;\r\n    if (stopsCount >= maxStops) {\r\n        // Threshold met. Transition to Parking.\r\n        return ['MarkAsParked', 'SaveCurrentTelemetry', 'GenerateTripSummary'];\r\n    } else {\r\n        // Still driving inside the school zone.\r\n        return ['IncrementStops', 'SaveCurrentTelemetry'];\r\n    }\r\n}",
        "tbelScript" : "function nextRelation(metadata, msg) {\n    return ['one','nine'];\n}\nif(msgType == 'POST_TELEMETRY_REQUEST') {\n    return ['two'];\n}\nreturn nextRelation(metadata, msg);"
      },
      "configurationVersion" : 0,
      "createdTime" : 0,
      "debugSettings" : {
