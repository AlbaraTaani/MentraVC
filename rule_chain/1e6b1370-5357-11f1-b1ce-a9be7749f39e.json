        "scriptLang" : "JS",
        "jsScript" : "var isParking = metadata.ss_is_bus_parking === 'true';\r\nvar stopsCount = parseInt(metadata.ss_current_stops_count || '0');\r\nvar relations = ['SaveCurrentTelemetry']; // Always save the live data when outside\r\n\r\nif (isParking) {\r\n    // Bus just left the school after being parked. Start new trip.\r\n    relations.push('StartNewTrip');\r\n} else if (stopsCount > 0) {\r\n    // Bus was inside the zone but didn't stay long enough to park. Reset the counter.\r\n    relations.push('ResetStops');\r\n}\r\n\r\nreturn relations;",
        "tbelScript" : "function nextRelation(metadata, msg) {\n    return ['one','nine'];\n}\nif(msgType == 'POST_TELEMETRY_REQUEST') {\n    return ['two'];\n}\nreturn nextRelation(metadata, msg);"
