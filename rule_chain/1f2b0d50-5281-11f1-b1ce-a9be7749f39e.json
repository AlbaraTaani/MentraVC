      },
      "configuration" : {
        "scriptLang" : "JS",
        "jsScript" : "var lat = msg.latitude;\r\nvar lon = msg.longitude;\r\nvar motion = msg.motion_status;\r\n\r\n// Retrieve state from metadata (defaults to ended if empty)\r\nvar state = metadata.ss_trip_state || 'ended';\r\nvar startTime = metadata.ss_trip_start_time;\r\nvar perimeterStr = metadata.ss_perimeter; \r\n\r\nvar isInside = false;\r\n\r\n// 1. Geofence Calculation (Haversine)\r\nif (perimeterStr && lat !== undefined && lon !== undefined) {\r\n    var p = JSON.parse(perimeterStr);\r\n    var R = 6371; // Earth's radius in km\r\n    var dLat = (p.latitude - lat) * Math.PI / 180;\r\n    var dLon = (p.longitude - lon) * Math.PI / 180;\r\n    var a = Math.sin(dLat/2) * Math.sin(dLat/2) + \r\n            Math.cos(lat * Math.PI / 180) * Math.cos(p.latitude * Math.PI / 180) * \r\n            Math.sin(dLon/2) * Math.sin(dLon/2);\r\n    var distanceKm = R * (2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a))); \r\n    \r\n    isInside = (distanceKm <= p.radius);\r\n}\r\n\r\n// 2. State Machine Logic & Payload Formatting\r\nvar now = Date.now();\r\n\r\nif (state === 'ended' && motion === 'moving' && !isInside) {\r\n    // Format for START: Payload designed for Save Attributes\r\n    msg = { \r\n        trip_state: 'active', \r\n        trip_start_time: now \r\n    };\r\n    metadata.route = \"START_ROUTE\";\r\n} \r\nelse if (state === 'active' && motion === 'stopped' && isInside) {\r\n    // Format for END: Satisfies strict telemetry output requirement\r\n    msg = { \r\n        start_time: parseInt(startTime), \r\n        end_time: now \r\n    };\r\n    metadata.route = \"END_ROUTE\";\r\n} \r\nelse {\r\n    // Kills the message immediately to save database resources\r\n    return null; \r\n}\r\n\r\nreturn {msg: msg, metadata: metadata, msgType: msgType};",
        "tbelScript" : "return {msg: msg, metadata: metadata, msgType: msgType};"
      },
