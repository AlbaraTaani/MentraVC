      },
      "configuration" : {
        "scriptLang" : "JS",
        "jsScript" : "var metricName = Object.keys(msg)[0]; \r\nvar val = parseFloat(msg[metricName]);\r\nvar now = new Date().getTime();\r\n\r\n// FIX 1: Read using the 'ss_' prefix applied by ThingsBoard\r\nvar windowSecs = parseInt(metadata.ss_monitoring_window_seconds || 120);\r\nvar lastEval = parseInt(metadata.ss_last_eval_time || now);\r\n\r\nvar sumKey = metricName + \"_sum\";\r\nvar countKey = metricName + \"_count\";\r\n\r\n// FIX 2: Read current tally using 'ss_', then add the incoming value\r\nvar currentSum = parseFloat(metadata[\"ss_\" + sumKey] || 0) + val;\r\nvar currentCount = parseInt(metadata[\"ss_\" + countKey] || 0) + 1;\r\n\r\n// Write back to metadata without 'ss_' so the Save node uses the clean database key\r\nmetadata[sumKey] = currentSum.toString();\r\nmetadata[countKey] = currentCount.toString();\r\n\r\nif (now - lastEval < (windowSecs * 1000)) {\r\n    var attributesToSave = {};\r\n    attributesToSave[sumKey] = currentSum;\r\n    attributesToSave[countKey] = currentCount;\r\n    if (!metadata.ss_last_eval_time) attributesToSave.last_eval_time = now;\r\n    \r\n    metadata.route_action = \"SAVE_TALLIES\";\r\n    return {msg: attributesToSave, metadata: metadata, msgType: \"POST_ATTRIBUTES_REQUEST\"};\r\n}\r\n\r\n// Window is closed! Calculate averages.\r\nvar metrics = [\"humidity\", \"comfort_score\", \"employees_present\"];\r\nvar newTelemetry = {};\r\nvar resetAttributes = { \"last_eval_time\": now };\r\nvar overall = \"normal\";\r\n\r\nfor (var i = 0; i < metrics.length; i++) {\r\n    var m = metrics[i];\r\n    // Use the newly calculated tally for the active metric, or fetch 'ss_' for the others\r\n    var mSum = parseFloat(m === metricName ? currentSum : (metadata[\"ss_\" + m + \"_sum\"] || 0));\r\n    var mCount = parseInt(m === metricName ? currentCount : (metadata[\"ss_\" + m + \"_count\"] || 0));\r\n    var status = \"unknown\"; \r\n\r\n    if (mCount > 0) {\r\n        var avg = mSum / mCount;\r\n        if (avg >= 40 && avg <= 70) status = \"normal\";\r\n        else if ((avg >= 25 && avg <= 39) || (avg >= 71 && avg <= 85)) status = \"attention\";\r\n        else status = \"alert\";\r\n    }\r\n\r\n    newTelemetry[m + \"_status\"] = status;\r\n    resetAttributes[m + \"_sum\"] = 0;\r\n    resetAttributes[m + \"_count\"] = 0;\r\n\r\n    if (status === \"alert\") overall = \"alert\";\r\n    else if (status === \"attention\" && overall !== \"alert\") overall = \"attention\";\r\n    else if (status === \"unknown\" && overall === \"normal\") overall = \"unknown\";\r\n}\r\n\r\nnewTelemetry.overall_room_status = overall;\r\nmetadata.resetAttributes = JSON.stringify(resetAttributes);\r\n\r\nmetadata.route_action = \"SAVE_STATUS\";\r\nreturn {msg: newTelemetry, metadata: metadata, msgType: \"POST_TELEMETRY_REQUEST\"};",
        "tbelScript" : "var newMsg = {};\r\nfor (var key in msg) {\r\n    var val = parseFloat(msg[key]);\r\n    var status = \"alert\";\r\n    \r\n    if (val >= 40 && val <= 70) {\r\n        status = \"normal\";\r\n    } else if ((val >= 25 && val <= 39) || (val >= 71 && val <= 85)) {\r\n        status = \"attention\";\r\n    }\r\n    \r\n    newMsg[key] = val; // Keep original metric\r\n    newMsg[key + \"_status\"] = status; // Create a new telemetry key for the status\r\n}\r\nreturn {msg: newMsg, metadata: metadata, msgType: msgType};"
      },
